{
  "name": "laravel-tesis",
  "type": "WEB",
  "strategy": {
    "type": "DEPLOYMENT_STRATEGY_TYPE_ROLLING"
  },
  "routes": [
    {
      "port": 8000,
      "path": "/"
    }
  ],
  "ports": [
    {
      "port": 8000,
      "protocol": "http"
    }
  ],
  "env": [
    { "key": "APP_NAME", "value": "Laravel" },
    { "key": "APP_ENV", "value": "production" },
    { "key": "APP_DEBUG", "value": "false" },
    { "key": "APP_KEY", "value": "base64:0CBC0wPtXDGoHpXpQS0dA2fCwkewgK4pQE26A8g0xo8=" },
    { "key": "APP_URL", "value": "https://laravel-tesis-tu-usuario.koyeb.app" },
    { "key": "APP_LOCALE", "value": "en" },
    { "key": "APP_FALLBACK_LOCALE", "value": "en" },
    { "key": "APP_FAKER_LOCALE", "value": "en_US" },
    { "key": "LOG_CHANNEL", "value": "stderr" },
    { "key": "LOG_LEVEL", "value": "debug" },
    { "key": "DB_CONNECTION", "value": "pgsql" },
    { "key": "DB_HOST", "value": "REEMPLAZAR_CON_HOST_POSTGRES" },
    { "key": "DB_PORT", "value": "5432" },
    { "key": "DB_DATABASE", "value": "REEMPLAZAR_CON_DATABASE" },
    { "key": "DB_USERNAME", "value": "REEMPLAZAR_CON_USER" },
    { "key": "DB_PASSWORD", "value": "REEMPLAZAR_CON_PASSWORD" },
    { "key": "FACE_SERVER_URL", "value": "https://face-server-tesis-TU_USUARIO.koyeb.app" },
    { "key": "FACE_SERVER_HOST", "value": "face-server-tesis-TU_USUARIO.koyeb.app" },
    { "key": "FACE_SERVER_PORT", "value": "443" },
    { "key": "FACE_HTTP_PORT", "value": "8000" },
    { "key": "FACE_WS_PORT", "value": "8000" },
    { "key": "SESSION_DRIVER", "value": "database" },
    { "key": "SESSION_LIFETIME", "value": "120" },
    { "key": "BCRYPT_ROUNDS", "value": "12" },
    { "key": "FILESYSTEM_DISK", "value": "local" },
    { "key": "QUEUE_CONNECTION", "value": "database" },
    { "key": "CACHE_STORE", "value": "database" },
    { "key": "MEMCACHED_HOST", "value": "127.0.0.1" },
    { "key": "REDIS_HOST", "value": "127.0.0.1" },
    { "key": "REDIS_PASSWORD", "value": "null" },
    { "key": "REDIS_PORT", "value": "6379" },
    { "key": "MAIL_MAILER", "value": "log" },
    { "key": "MAIL_FROM_ADDRESS", "value": "hello@example.com" },
    { "key": "MAIL_FROM_NAME", "value": "Laravel" }
  ],
  "regions": ["was"],
  "scalings": [
    {
      "scopes": ["region:was"],
      "min": 1,
      "max": 1,
      "targets": []
    }
  ],
  "instance_types": [
    {
      "scopes": ["region:was"],
      "type": "nano"
    }
  ],
  "health_checks": [
    {
      "grace_period": 60,
      "interval": 30,
      "restart_limit": 3,
      "timeout": 10,
      "http": {
        "path": "/up",
        "port": 8000
      }
    }
  ],
  "git": {
    "repository": "github.com/royeisson/laravel_tesis",
    "branch": "main",
    "docker": {
      "dockerfile": "Dockerfile",
      "entrypoint": [],
      "command": [],
      "args": [],
      "target": "",
      "privileged": false
    }
  }
}
